# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gismart?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
SESSION_SECRET=replace-with-another-long-random-string

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (set to your deployed URL in production) ────────────────────────────
CLIENT_URL=https://your-app.onrender.com

# ── Admin (optional) ─────────────────────────────────────────────────────────
# Comma-separated emails that get admin UI + /admin access without changing MongoDB role.
# Prefer setting role: "admin" on the user in Atlas; use this if you cannot update the DB.
# ADMIN_EMAILS=you@example.com
